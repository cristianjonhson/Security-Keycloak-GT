{
	"info": {
		"_postman_id": "4740b882-9e3d-4f10-ad62-235e1a21857d",
		"name": "CURS-000188-Keycloak",
		"description": "Coleccion para autenticacion Keycloak y pruebas de la API Gestion Academica.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "17675229"
	},
	"variable": [
		{
			"key": "keycloak_protocol",
			"value": "http"
		},
		{
			"key": "keycloak_host",
			"value": "localhost"
		},
		{
			"key": "keycloak_port",
			"value": "6082"
		},
		{
			"key": "realm",
			"value": "REALM_DEMO_V1"
		},
		{
			"key": "client_id",
			"value": "app-web-v1"
		},
		{
			"key": "username",
			"value": "anovoa"
		},
		{
			"key": "password",
			"value": "123"
		},
		{
			"key": "scope",
			"value": "basic"
		},
		{
			"key": "api_base_url",
			"value": "http://localhost:8082/api-gestion-academica"
		},
		{
			"key": "company_search",
			"value": "Centro"
		},
		{
			"key": "expected_status_endpoint2",
			"value": "403"
		},
		{
			"key": "expected_status_endpoint3",
			"value": "403"
		},
		{
			"key": "access_token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "00 - Auth",
			"description": "Obtencion de token y validaciones de autenticacion.",
			"item": [
				{
					"name": "Get Token (Password Grant)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "client_id",
									"value": "{{client_id}}",
									"type": "text"
								},
								{
									"key": "grant_type",
									"value": "password",
									"type": "text"
								},
								{
									"key": "username",
									"value": "{{username}}",
									"type": "text"
								},
								{
									"key": "password",
									"value": "{{password}}",
									"type": "text"
								},
								{
									"key": "scope",
									"value": "{{scope}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{keycloak_protocol}}://{{keycloak_host}}:{{keycloak_port}}/realms/{{realm}}/protocol/openid-connect/token",
							"host": [
								"{{keycloak_host}}"
							],
							"port": "{{keycloak_port}}",
							"path": [
								"realms",
								"{{realm}}",
								"protocol",
								"openid-connect",
								"token"
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"const response = pm.response.json();",
									"pm.test('Response contains access token', function () {",
									"  pm.expect(response.access_token).to.exist;",
									"});",
									"pm.collectionVariables.set('access_token', response.access_token);",
									"pm.collectionVariables.set('refresh_token', response.refresh_token || '');",
									"pm.collectionVariables.set('token_type', response.token_type || 'Bearer');",
									"pm.test('Token type is Bearer', function () {",
									"  pm.expect((response.token_type || '').toLowerCase()).to.eql('bearer');",
									"});"
								]
							}
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "10 - Public API",
			"description": "Endpoints publicos de la API.",
			"item": [
				{
					"name": "GET Public Demo",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{api_base_url}}/api/v1/test/libre/demo"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"  pm.response.to.have.status(200);",
									"});"
								]
							}
						}
					],
					"response": []
				}
			]
		},
		{
			"name": "20 - Protected API",
			"description": "Endpoints privados que requieren bearer token. Ajusta expected_status_endpoint2 y expected_status_endpoint3 segun el rol autenticado (200 permitido, 403 denegado).",
			"item": [
				{
					"name": "GET Companies",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{api_base_url}}/api/v1/companies"
						}
					},
					"response": []
				},
				{
					"name": "GET Companies by Name",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{api_base_url}}/api/v1/companies/by-company?company={{company_search}}"
						}
					},
					"response": []
				},
				{
					"name": "GET Private Endpoint 1 (admin)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{api_base_url}}/api/v1/test/private/endpoint1"
						}
					},
					"response": []
				},
				{
					"name": "GET Private Endpoint 2 (director_Academico)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{api_base_url}}/api/v1/test/private/endpoint2"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const expected = Number(pm.collectionVariables.get('expected_status_endpoint2') || 403);",
									"pm.test('Endpoint2 status segun rol esperado', function () {",
									"  pm.response.to.have.status(expected);",
									"});",
									"if (expected === 200) {",
									"  pm.test('Respuesta permitida contiene texto de director', function () {",
									"    pm.expect(pm.response.text().toLowerCase()).to.include('director');",
									"  });",
									"}"
								]
							}
						}
					],
					"response": []
				},
				{
					"name": "GET Private Endpoint 3 (profesor)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{api_base_url}}/api/v1/test/private/endpoint3"
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const expected = Number(pm.collectionVariables.get('expected_status_endpoint3') || 403);",
									"pm.test('Endpoint3 status segun rol esperado', function () {",
									"  pm.response.to.have.status(expected);",
									"});",
									"if (expected === 200) {",
									"  pm.test('Respuesta permitida contiene texto de profesor', function () {",
									"    pm.expect(pm.response.text().toLowerCase()).to.include('profesor');",
									"  });",
									"}"
								]
							}
						}
					],
					"response": []
				}
			]
		}
	]
}
